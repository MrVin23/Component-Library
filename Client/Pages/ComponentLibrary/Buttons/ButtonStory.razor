@page "/componentlibrary-button"
@using Client.Components.Buttons.CustomButton
@using Client.Components.Containers.TitleContainer

<PageTitle>Buttons</PageTitle>

<TitleContainer
    Title="Buttons"
    Description="CustomButton uses the global theme, spacing, border, and shadow tokens." />

<GridDisplay ColumnHeaders="@SizeColumnHeaders">
    @foreach (var variant in StoryVariants)
    {
        <GridDisplayRow Label="@TypeLabel(variant)" LabelId="@($"size-row-{variant}")">
            <GridDisplayCell>
                <CustomButton ButtonType="variant"
                              Size="CustomButtonSize.Small"
                              Text="@TypeLabel(variant)" />
            </GridDisplayCell>
            <GridDisplayCell>
                <CustomButton ButtonType="variant"
                              Size="CustomButtonSize.Medium"
                              Text="@TypeLabel(variant)" />
            </GridDisplayCell>
            <GridDisplayCell>
                <CustomButton ButtonType="variant"
                              Size="CustomButtonSize.Large"
                              Text="@TypeLabel(variant)" />
            </GridDisplayCell>
        </GridDisplayRow>
    }
</GridDisplay>

@code {
    private static readonly string[] SizeColumnHeaders = ["Small", "Medium", "Large"];

    /// <summary>Tertiary is third row after Secondary (not enum declaration order).</summary>
    private static readonly CustomButtonType[] StoryVariants =
    [
        CustomButtonType.Primary,
        CustomButtonType.Secondary,
        CustomButtonType.Tertiary,
        CustomButtonType.FormGreen,
        CustomButtonType.FormGrey,
        CustomButtonType.FormBlue,
        CustomButtonType.FormPurple,
        CustomButtonType.Pager,
        CustomButtonType.Danger,
        CustomButtonType.Ghost,
        CustomButtonType.Generate,
    ];

    private static string TypeLabel(CustomButtonType type) => type switch
    {
        CustomButtonType.Primary => "Primary",
        CustomButtonType.Secondary => "Secondary",
        CustomButtonType.FormGreen => "Form green",
        CustomButtonType.FormGrey => "Form grey",
        CustomButtonType.FormBlue => "Form blue",
        CustomButtonType.FormPurple => "Form purple",
        CustomButtonType.Pager => "Pager",
        CustomButtonType.Danger => "Danger",
        CustomButtonType.Ghost => "Ghost",
        CustomButtonType.Tertiary => "Tertiary",
        CustomButtonType.Generate => "Generate",
        _ => type.ToString()
    };
}
