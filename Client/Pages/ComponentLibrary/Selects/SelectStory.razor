@page "/componentlibrary-selects"
@using Client.Components.CustomSelect
@using Client.Components.Containers.TitleContainer

<PageTitle>Selects</PageTitle>

<TitleContainer
    Title="Selects"
    Description="CustomSelect, CustomSearchSelect, and CustomMultiSelect use app-field, app-label, and app-input tokens. Search and multi variants list options in CustomDropdownPanel." />

<BaseContainer Border="true">
    <section class="select-story__section" aria-labelledby="native-select-heading">
        <h2 id="native-select-heading" class="select-story__h2">CustomSelect</h2>
        <p class="select-story__muted">Native select element with Primary density.</p>

        <div class="select-story__sample">
            <CustomSelect TItem="string"
                          Label="Region"
                          Items="@DemoItems"
                          @bind-SelectedValue="_nativeSelected"
                          Placeholder="Choose a region"
                          SelectType="CustomSelectType.Primary"
                          Width="100%" />
            <p class="select-story__state" role="status">
                Selected: <strong>@FormatSelection(_nativeSelected)</strong>
            </p>
        </div>
    </section>

    <section class="select-story__section" aria-labelledby="search-select-heading">
        <h2 id="search-select-heading" class="select-story__h2">CustomSearchSelect</h2>
        <p class="select-story__muted">Single choice with filter.</p>

        <div class="select-story__sample">
            <CustomSearchSelect TItem="string"
                                Label="Region"
                                Items="@DemoItems"
                                @bind-SelectedValue="_searchSelected"
                                Placeholder="Choose a region"
                                SelectType="CustomSelectType.Primary"
                                Width="100%" />
            <p class="select-story__state" role="status">
                Selected: <strong>@FormatSelection(_searchSelected)</strong>
            </p>
        </div>
    </section>

    <section class="select-story__section" aria-labelledby="multi-select-heading">
        <h2 id="multi-select-heading" class="select-story__h2">CustomMultiSelect</h2>
        <p class="select-story__muted">Multiple selection with select-all header and filter.</p>

        <div class="select-story__sample">
            <CustomMultiSelect TItem="string"
                               Label="Regions"
                               Items="@DemoItems"
                               @bind-SelectedValues="_multiSelected"
                               Placeholder="Pick one or more"
                               SelectType="CustomSelectType.Primary"
                               Width="100%" />
            <p class="select-story__state" role="status">
                Count: <strong>@_multiSelected.Count</strong> — @FormatMultiSelection(_multiSelected)
            </p>
        </div>
    </section>
</BaseContainer>

@code {
    private static readonly List<string> DemoItems = ["North", "South", "East", "West", "Central"];

    private string? _nativeSelected;
    private string? _searchSelected;
    private List<string> _multiSelected = [];

    private static string FormatSelection(string? value) =>
        string.IsNullOrEmpty(value) ? "—" : value;

    private static string FormatMultiSelection(IReadOnlyList<string> values) =>
        values.Count == 0 ? "—" : string.Join(", ", values);
}
