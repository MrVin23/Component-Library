@page "/usermanagement-roles"
@layout MainLayout
@using Client.Apis.UserPermissions
@using Client.Components.Authorization
@using Client.Components.Breadcrumbs
@using Client.Components.Containers.FormContainer
@using Client.Components.Containers.TitleContainer
@using Client.Components.Table
@using Client.Components.Validation
@using Shared.Dtos.UserPermissions

<CustomAutorizeView Role="Admin">
    <TitleContainer
        Title="Role management"
        Description="Create, update, and remove roles used for grouping permissions and user assignments." />

    <section class="user-management role-management">
    <BreadCrumbs Items="BreadcrumbItems" CssClass="role-management__breadcrumbs" />

    @if (!string.IsNullOrEmpty(bannerMessage))
    {
        <div class="@BannerCssClass" role="@(bannerIsError ? "alert" : "status")">@bannerMessage</div>
    }

    <div class="role-management__layout">
        <EditForm Model="@createRequest" OnSubmit="@HandleCreateSubmitAsync">
            <FormContainer Title="@PrimaryFormTitle"
                           ShowTitle="true"
                           ShowResetButton="true"
                           ResetButtonText="@(editingRoleId.HasValue ? "Cancel" : "Reset")"
                           ShowSaveButton="true"
                           ShowValidationSummary="true"
                           SaveButtonHtmlType="submit"
                           ResetButtonHtmlType="button"
                           SaveDisabled="@isSaving"
                           ResetDisabled="@isSaving"
                           OnReset="@HandleCreateResetAsync">
                <div class="role-management__fields @(highlightPrimaryForm ? "role-management__fields--highlight" : string.Empty)">
                    <label class="app-field">
                        <span class="app-label">Role name <span class="app-label-req">*</span></span>
                        <InputText class="app-input" @bind-Value="createRequest.Name" placeholder="e.g. Warehouse staff" autocomplete="off" />
                        <ValidationMessage For="@(() => createRequest.Name)" />
                    </label>
                    <label class="app-field">
                        <span class="app-label">Description</span>
                        <InputTextArea class="app-textarea role-management__textarea" @bind-Value="createRequest.Description" placeholder="Optional description for this role" />
                        <ValidationMessage For="@(() => createRequest.Description)" />
                    </label>
                </div>
            </FormContainer>
        </EditForm>

        <div class="role-management__list-panel">
            <h2 class="role-management__list-title">Existing roles</h2>

            <div class="role-management__table-wrap">
                <CustomTable TItem="RoleWithPermissionsResponse"
                             Items="@roles"
                             IsLoading="@isLoadingList"
                             EmptyMessage="No roles found."
                             LoadingMessage="Loading roles...">
                    <HeaderTemplate>
                        <th scope="col">Name</th>
                        <th scope="col" class="role-management__col-description">Description</th>
                        <th scope="col" class="role-management__col-actions">Actions</th>
                    </HeaderTemplate>
                    <RowTemplate Context="role">
                        <td>
                            <code class="role-management__code">@role.Name</code>
                        </td>
                        <td class="role-management__col-description">@(string.IsNullOrWhiteSpace(role.Description) ? "-" : role.Description)</td>
                        <td class="role-management__col-actions">
                            <TableActionsCell TItem="RoleWithPermissionsResponse"
                                              Item="@role"
                                              IsDisabled="@(isSaving || isDeletingId == role.Id)"
                                              OnEdit="@((RoleWithPermissionsResponse row) => StartEditFromRowAsync(row))"
                                              OnDelete="@((RoleWithPermissionsResponse row) => DeleteRoleFromRowAsync(row))" />
                        </td>
                    </RowTemplate>
                </CustomTable>
            </div>
        </div>
    </div>

        <Snackbar @ref="feedbackSnackbar" />
    </section>
</CustomAutorizeView>
