@namespace Client.Components.CustomSelect
@typeparam TItem

<div class="app-field @ContainerCssClass" style="width: @Width;">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="app-label @LabelCssClass">@Label</label>
    }
    <div class="custom-select-wrapper @(_isOpen ? "is-open" : "") @(HasSelection ? "custom-select-has-selection" : "")">
        <div class="custom-select-input-wrapper"
             @ref="_triggerRef"
             @onmousedown="OnTriggerMouseDown">
            <input type="text"
                   class="app-input custom-select-input-main @InputCssClass"
                   style="height: @Height;"
                   placeholder="@Placeholder"
                   value="@InputValue"
                   @ref="_inputRef"
                   readonly
                   @onfocus="OnInputFocus"
                   @onclick="OnInputClick"
                   @onkeydown="OnInputKeyDown"
                   disabled="@Disabled"
                   @attributes="AdditionalAttributes" />
            <div class="custom-select-trigger-actions">
                @if (HasSelection)
                {
                    <button type="button"
                            class="custom-select-trigger-clear"
                            aria-label="Clear selection"
                            disabled="@Disabled"
                            @onclick="ClearSelection"
                            @onclick:stopPropagation="true"
                            @onmousedown:preventDefault="true">
                        <i class="bi bi-x-lg" aria-hidden="true"></i>
                    </button>
                }
                <span class="custom-select-trigger-chevron"
                      role="button"
                      tabindex="0"
                      aria-label="Toggle list"
                      @onclick="OnChevronClick"
                      @onclick:stopPropagation="true"
                      @onkeydown="OnChevronKeyDown">▼</span>
            </div>
        </div>

        <CustomDropdownPanel @ref="_dropdownPanel" IsOpen="_isOpen" OnClose="CloseDropdown">
            <div class="custom-select-dropdown">
                <div class="custom-select-items">
                    @if (Items.Count > 0)
                    {
                        @foreach (var item in Items)
                        {
                            <div @key="ValueFunc(item)"
                                 class="custom-select-item @(EqualityComparer<TItem>.Default.Equals(item, SelectedValue) ? "selected" : "")"
                                 @onclick="() => SelectItem(item)"
                                 @onclick:stopPropagation="true"
                                 @onmousedown:preventDefault="true">
                                @DisplayFunc(item)
                            </div>
                        }
                    }
                    else
                    {
                        <div class="custom-select-item no-results">No items available</div>
                    }
                </div>
            </div>
        </CustomDropdownPanel>
    </div>
</div>
