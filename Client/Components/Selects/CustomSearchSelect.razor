@namespace Client.Components.CustomSelect
@typeparam TItem

<div class="app-field @ContainerCssClass" style="width: @Width;">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="app-label @LabelCssClass">@Label</label>
    }
    @* Keep this wrapper as a plain div.
       If parent pages wrap this component in an outer <label>, focus can bounce back to the input after selection
       and visually reopen the panel. Prefer <div class="app-field"> wrappers in consuming pages. *@
    <div class="custom-search-select-wrapper @(_isOpen ? "is-open" : "") @(HasSelection ? "custom-select-has-selection" : "")">
        <div class="custom-search-select-input-wrapper"
             @ref="_triggerRef"
             @onmousedown="OnTriggerMouseDown">
            <input type="text"
                   class="app-input custom-search-select-input-main"
                   style="height: @Height;"
                   placeholder="@InputPlaceholder"
                   value="@InputValue"
                   @ref="_inputRef"
                   @onfocus="OnInputFocus"
                   @onblur="OnInputBlur"
                   @onclick="OnInputClick"
                   @oninput="OnSearchInput"
                   @onkeydown="OnInputKeyDown"
                   disabled="@Disabled"
                   @attributes="AdditionalAttributes" />
            <div class="custom-select-trigger-actions">
                @if (HasSelection)
                {
                    <button type="button"
                            class="custom-select-trigger-clear"
                            aria-label="Clear selection"
                            disabled="@Disabled"
                            @onclick="ClearSelection"
                            @onclick:stopPropagation="true"
                            @onmousedown:preventDefault="true">
                        <i class="bi bi-x-lg" aria-hidden="true"></i>
                    </button>
                }
                <span class="custom-select-trigger-chevron"
                      role="button"
                      tabindex="0"
                      aria-label="Toggle list"
                      @onclick="OnChevronClick"
                      @onclick:stopPropagation="true"
                      @onkeydown="OnChevronKeyDown">▼</span>
            </div>
        </div>
        
        <CustomDropdownPanel @ref="_dropdownPanel" IsOpen="_isOpen" OnClose="() => { _isOpen = false; _searchText = string.Empty; }">
            <div class="custom-search-select-dropdown">
                <div class="custom-search-select-items">
                    @if (FilteredItems.Any())
                    {
                        @foreach (var item in FilteredItems)
                        {
                            @* preventDefault on mousedown is important: it avoids blur/click timing races while selecting,
                               so SelectItem can close the panel deterministically. *@
                            <div @key="ValueFunc(item)"
                                 class="custom-search-select-item @(EqualityComparer<TItem>.Default.Equals(item, SelectedValue) ? "selected" : "")"
                                 @onclick="() => SelectItem(item)"
                                 @onclick:stopPropagation="true"
                                 @onmousedown:preventDefault="true">
                                @DisplayFunc(item)
                            </div>
                        }
                    }
                    else if (!string.IsNullOrWhiteSpace(_searchText))
                    {
                        <div class="custom-search-select-item no-results">No results found</div>
                    }
                    else
                    {
                        <div class="custom-search-select-item no-results">No items available</div>
                    }
                </div>
            </div>
        </CustomDropdownPanel>
    </div>
</div>
