@namespace Client.Components.Authorization
@* security risk: DEMO ONLY — remove @using Client.Routes and @inject NavigationManager before production. *@
@using Client.Apis
@using Client.Routes
@inject ApiAntiforgery ApiAntiforgery
@inject AntiforgeryTokenStore AntiforgeryTokens
@inject NavigationManager Navigation

@if (!_ready && _error is null)
{
    <div class="antiforgery-bootstrap">Loading…</div>
}
else if (_error is not null)
{
    <div class="antiforgery-bootstrap antiforgery-bootstrap--error">
        <p>@_error</p>
        <button type="button" class="btn btn-primary" @onclick="RetryAsync">Retry</button>
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _ready;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        // security risk: DEMO ONLY — remove this block before production; always require a valid antiforgery token.
        if (ComponentLibraryRoutes.IsPublicStoryRoute(Navigation))
        {
            _ready = true;
            return;
        }

        await LoadTokenAsync();
    }

    private async Task RetryAsync()
    {
        _error = null;
        _ready = false;
        await LoadTokenAsync();
        StateHasChanged();
    }

    private async Task LoadTokenAsync()
    {
        try
        {
            var dto = await ApiAntiforgery.GetRequestTokenAsync();
            if (string.IsNullOrEmpty(dto?.RequestToken))
            {
                // security risk: DEMO ONLY — revert to setting _error and not rendering ChildContent.
                ProceedWithoutToken();
                return;
            }

            AntiforgeryTokens.RequestToken = dto.RequestToken;
            _ready = true;
        }
        catch
        {
            // security risk: DEMO ONLY — revert to setting _error and not rendering ChildContent.
            ProceedWithoutToken();
        }
    }

    // security risk: DEMO ONLY — remove this method before production.
    private void ProceedWithoutToken()
    {
        if (!ComponentLibraryRoutes.IsPublicStoryRoute(Navigation))
            Navigation.NavigateTo(ComponentLibraryRoutes.DefaultRoute, replace: true);

        _error = null;
        _ready = true;
    }
}
